<svg viewBox="0 0 1280 340" xmlns="http://www.w3.org/2000/svg" font-family="'Segoe UI', system-ui, -apple-system, sans-serif">
  <defs>
    <!-- dot grid pattern -->
    <pattern id="grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
      <circle cx="0.8" cy="0.8" r="0.8" fill="#ffffff" opacity="0.055"/>
    </pattern>
    <!-- orange glow -->
    <radialGradient id="glowEmber" cx="18%" cy="55%" r="45%" gradientUnits="objectBoundingBox">
      <stop offset="0%"   stop-color="#FF5B35" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="#FF5B35" stop-opacity="0"/>
    </radialGradient>
    <!-- blue glow -->
    <radialGradient id="glowBlue" cx="82%" cy="45%" r="45%" gradientUnits="objectBoundingBox">
      <stop offset="0%"   stop-color="#4F9EFF" stop-opacity="0.10"/>
      <stop offset="100%" stop-color="#4F9EFF" stop-opacity="0"/>
    </radialGradient>
    <!-- subtle center glow -->
    <radialGradient id="glowCenter" cx="50%" cy="50%" r="50%" gradientUnits="objectBoundingBox">
      <stop offset="0%"   stop-color="#1C1C2E" stop-opacity="1"/>
      <stop offset="100%" stop-color="#050508" stop-opacity="1"/>
    </radialGradient>
    <!-- border gradient -->
    <linearGradient id="borderLine" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="#FF5B35" stop-opacity="0"/>
      <stop offset="30%"  stop-color="#FF5B35" stop-opacity="0.5"/>
      <stop offset="70%"  stop-color="#4F9EFF" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="#4F9EFF" stop-opacity="0"/>
    </linearGradient>
    <!-- logo gradient -->
    <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#FF7A55"/>
      <stop offset="100%" stop-color="#FF3B10"/>
    </linearGradient>
    <!-- wordmark gradient -->
    <linearGradient id="wordmarkGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="#FFFFFF"/>
      <stop offset="100%" stop-color="#EEEEF8"/>
    </linearGradient>
    <!-- sketch stroke animation feel -->
    <filter id="glow-fx" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
      <feComposite in="SourceGraphic" in2="blur" operator="over"/>
    </filter>
  </defs>

  <!-- ── BASE ── -->
  <rect width="1280" height="340" fill="#050508"/>
  <rect width="1280" height="340" fill="url(#glowCenter)"/>
  <rect width="1280" height="340" fill="url(#grid)"/>
  <rect width="1280" height="340" fill="url(#glowEmber)"/>
  <rect width="1280" height="340" fill="url(#glowBlue)"/>

  <!-- ── TOP ACCENT LINE ── -->
  <rect x="0" y="0" width="1280" height="1" fill="url(#borderLine)" opacity="0.6"/>
  <!-- ── BOTTOM ACCENT LINE ── -->
  <rect x="0" y="339" width="1280" height="1" fill="url(#borderLine)" opacity="0.4"/>

  <!-- ═══════════════════════════════════════
       LEFT SIDE — SKETCH PANEL  (x: 60–460)
  ═══════════════════════════════════════ -->
  <!-- Sketch panel background -->
  <rect x="60" y="52" width="360" height="236" rx="16" fill="#0C0C14" stroke="#FFFFFF" stroke-width="0.6" stroke-opacity="0.08"/>

  <!-- panel label -->
  <rect x="72" y="64" width="62" height="18" rx="4" fill="#1C1C2E"/>
  <text x="80" y="76.5" font-size="9" fill="#EEEEF8" opacity="0.4" letter-spacing="0.08em" font-family="'Courier New', monospace">SKETCH</text>

  <!-- Mountain sketch lines inside panel -->
  <g transform="translate(80, 90)" stroke="#EEEEF8" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.75">
    <!-- Mountain 1 -->
    <path d="M10 160 L80 48 L150 160" stroke-width="2.2"/>
    <!-- Mountain 2 -->
    <path d="M100 160 L175 40 L252 160" stroke-width="2.2"/>
    <!-- Ground -->
    <path d="M0 160 L320 160" stroke-width="1.5"/>
    <!-- Sun -->
    <circle cx="225" cy="30" r="18" stroke-width="2"/>
    <!-- Trees -->
    <path d="M22 160 L22 142 L30 124 L38 142 L38 160" stroke-width="1.8"/>
    <path d="M50 160 L50 146 L57 130 L64 146 L64 160" stroke-width="1.8"/>
    <!-- Ground texture -->
    <path d="M0 168 Q80 164 160 167 Q240 170 320 164" stroke-width="1.2" opacity="0.5"/>
    <path d="M0 175 Q80 172 160 174 Q240 176 320 171" stroke-width="1.2" opacity="0.5"/>
  </g>

  <!-- panel dots (mac-style) -->
  <circle cx="79"  cy="260" r="3.5" fill="#FF5F57" opacity="0.7"/>
  <circle cx="92"  cy="260" r="3.5" fill="#FEBC2E" opacity="0.7"/>
  <circle cx="105" cy="260" r="3.5" fill="#28C840" opacity="0.7"/>

  <!-- ═══════════════════════════════════════
       CENTER ARROW
  ═══════════════════════════════════════ -->
  <g transform="translate(458, 148)">
    <!-- arrow track -->
    <rect x="0" y="14" width="72" height="2" rx="1" fill="url(#borderLine)" opacity="0.5"/>
    <!-- arrow head -->
    <path d="M58 8 L72 15 L58 22" stroke="#FF5B35" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <!-- ControlNet label -->
    <text x="36" y="10" text-anchor="middle" font-size="9" fill="#FF5B35" opacity="0.85" letter-spacing="0.06em" font-family="'Courier New', monospace">CONTROLNET</text>
  </g>

  <!-- ═══════════════════════════════════════
       RIGHT SIDE — AI RESULT PANEL (x: 550–920)
  ═══════════════════════════════════════ -->
  <rect x="550" y="52" width="360" height="236" rx="16" fill="#0C0C14" stroke="#FFFFFF" stroke-width="0.6" stroke-opacity="0.08"/>

  <!-- panel label -->
  <rect x="562" y="64" width="72" height="18" rx="4" fill="#1C1C2E"/>
  <text x="570" y="76.5" font-size="9" fill="#FF5B35" opacity="0.85" letter-spacing="0.08em" font-family="'Courier New', monospace">AI RESULT</text>

  <!-- Mountain art (stylised) -->
  <g transform="translate(566, 88)">
    <!-- Sky gradient layers -->
    <rect x="0" y="0" width="328" height="170" rx="6" fill="#0D1B2A"/>
    <!-- Sky colors -->
    <rect x="0" y="0"   width="328" height="60"  rx="0" fill="#FF6B35" opacity="0.28"/>
    <rect x="0" y="40"  width="328" height="60"  rx="0" fill="#C06030" opacity="0.22"/>
    <rect x="0" y="90"  width="328" height="80"  rx="0" fill="#0A1628" opacity="0.6"/>
    <!-- Sun glow -->
    <circle cx="238" cy="38" r="28" fill="#FFAA44" opacity="0.18"/>
    <circle cx="238" cy="38" r="18" fill="#FFD080" opacity="0.35"/>
    <circle cx="238" cy="38" r="10" fill="#FFE8A0" opacity="0.75"/>
    <!-- Mountain silhouettes -->
    <polygon points="0,170 90,58 180,170" fill="#1A2840" opacity="0.85"/>
    <polygon points="90,170 185,44 280,170" fill="#152235" opacity="0.9"/>
    <polygon points="180,170 270,80 328,170" fill="#1E3050" opacity="0.8"/>
    <!-- Mountain snow caps -->
    <polygon points="84,68 90,58 96,68" fill="#E8EEF5" opacity="0.7"/>
    <polygon points="178,55 185,44 192,55" fill="#E8EEF5" opacity="0.8"/>
    <!-- Reflection / water strip -->
    <rect x="0" y="148" width="328" height="22" fill="#0A1A30" rx="0"/>
    <rect x="20" y="152" width="80" height="2" rx="1" fill="#FFD080" opacity="0.2"/>
    <rect x="120" y="156" width="40" height="1.5" rx="1" fill="#FFD080" opacity="0.15"/>
    <rect x="200" y="153" width="60" height="2" rx="1" fill="#FFD080" opacity="0.1"/>
    <!-- Trees (dark silhouettes) -->
    <rect x="18" y="130" width="4" height="22" fill="#0A1220"/>
    <polygon points="12,135 20,110 28,135" fill="#0C1520"/>
    <polygon points="9,130 20,105 31,130" fill="#0E1825" opacity="0.9"/>
    <rect x="42" y="136" width="3" height="16" fill="#0A1220"/>
    <polygon points="37,140 43.5,120 50,140" fill="#0C1520"/>
    <!-- Pixel-feel noise overlay -->
    <rect x="0" y="0" width="328" height="170" fill="url(#grid)" opacity="0.3" rx="6"/>
  </g>

  <!-- panel dots -->
  <circle cx="569"  cy="260" r="3.5" fill="#FF5F57" opacity="0.7"/>
  <circle cx="582"  cy="260" r="3.5" fill="#FEBC2E" opacity="0.7"/>
  <circle cx="595"  cy="260" r="3.5" fill="#28C840" opacity="0.7"/>

  <!-- ═══════════════════════════════════════
       RIGHT TEXT BLOCK (x: 955)
  ═══════════════════════════════════════ -->

  <!-- Logo icon box -->
  <rect x="955" y="72" width="52" height="52" rx="14" fill="url(#logoGrad)"/>
  <!-- Logo pen icon -->
  <g transform="translate(967, 84)" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 4a3.3 3.3 0 0 1 4.7 4.7L8.7 24.3 2 26l1.7-6.7Z"/>
    <path d="m17.5 6.5 4.7 4.7"/>
  </g>

  <!-- NeuroDraw wordmark -->
  <text x="1018" y="107" font-size="42" font-weight="800" fill="url(#wordmarkGrad)" letter-spacing="-1.8" opacity="0.97">NeuroDraw</text>

  <!-- Tagline -->
  <text x="955" y="152" font-size="15.5" fill="#EEEEF8" opacity="0.52" letter-spacing="0.01em">Sketch → ControlNet → Stable Diffusion → Art</text>

  <!-- Divider line -->
  <rect x="955" y="168" width="280" height="1" fill="#FFFFFF" opacity="0.07"/>

  <!-- Tech chips row -->
  <!-- ControlNet chip -->
  <rect x="955" y="182" width="86" height="24" rx="6" fill="#131320" stroke="#FF5B35" stroke-width="0.8" stroke-opacity="0.5"/>
  <text x="998" y="198" text-anchor="middle" font-size="10.5" fill="#FF5B35" opacity="0.9" font-family="'Courier New', monospace">ControlNet</text>

  <!-- SD chip -->
  <rect x="1049" y="182" width="68" height="24" rx="6" fill="#131320" stroke="#4F9EFF" stroke-width="0.8" stroke-opacity="0.5"/>
  <text x="1083" y="198" text-anchor="middle" font-size="10.5" fill="#4F9EFF" opacity="0.9" font-family="'Courier New', monospace">SD v1.5</text>

  <!-- CLIP chip -->
  <rect x="1125" y="182" width="46" height="24" rx="6" fill="#131320" stroke="#34D399" stroke-width="0.8" stroke-opacity="0.5"/>
  <text x="1148" y="198" text-anchor="middle" font-size="10.5" fill="#34D399" opacity="0.9" font-family="'Courier New', monospace">CLIP</text>

  <!-- Stats -->
  <text x="955" y="236" font-size="13" fill="#EEEEF8" opacity="0.35" letter-spacing="0.01em">3–8 sec · 11 styles · 100% local · MIT license</text>

  <!-- Version badge -->
  <rect x="955" y="252" width="52" height="20" rx="4" fill="#FF5B35" opacity="0.15"/>
  <rect x="955" y="252" width="52" height="20" rx="4" stroke="#FF5B35" stroke-width="0.8" fill="none" opacity="0.4"/>
  <text x="981" y="265.5" text-anchor="middle" font-size="9.5" fill="#FF5B35" opacity="0.9" font-family="'Courier New', monospace">v1.0.0</text>

  <rect x="1014" y="252" width="52" height="20" rx="4" fill="#34D399" opacity="0.1"/>
  <rect x="1014" y="252" width="52" height="20" rx="4" stroke="#34D399" stroke-width="0.8" fill="none" opacity="0.35"/>
  <text x="1040" y="265.5" text-anchor="middle" font-size="9.5" fill="#34D399" opacity="0.9" font-family="'Courier New', monospace">MIT</text>

  <rect x="1073" y="252" width="64" height="20" rx="4" fill="#4F9EFF" opacity="0.1"/>
  <rect x="1073" y="252" width="64" height="20" rx="4" stroke="#4F9EFF" stroke-width="0.8" fill="none" opacity="0.35"/>
  <text x="1105" y="265.5" text-anchor="middle" font-size="9.5" fill="#4F9EFF" opacity="0.9" font-family="'Courier New', monospace">Flask+PyTorch</text>

</svg>
